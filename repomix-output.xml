                {#each resultsArtists as artist}
                    <a href="#artist/{artist.id}" class="card artist-card">
                        <img src={artist.imagePath ? `/api/Tracks/image?path=${encodeURIComponent(artist.imagePath.split('?')[0])}` : '/placeholder.png'} alt={artist.name} />
