.btn-icon-main { background: none; border: none; color: var(--text-primary); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: transform 0.15s cubic-bezier(0.4, 0, 0.2, 1); width: 48px; height: 48px; position: relative; }
.btn-icon-main:active { transform: scale(0.85); }
.btn-icon-main svg { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); }

.hidden { display: none !important; }

#nerdy-info { flex: 1; display: flex; align-items: center; gap: 24px; justify-content: flex-end; }
#file-badge { font-size: 10px; font-weight: 700; padding: 4px 6px; border-radius: 4px; background-color: rgba(255,255,255,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); letter-spacing: 1px; }

