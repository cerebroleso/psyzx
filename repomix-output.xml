        margin-top: -4px; 
        background: rgba(239, 68, 68, 0.1);
        padding: 10px;
        border-radius: 10px;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    /* BOTTONE CALL TO ACTION */
    .btn-auth {
        background: var(--accent-color); 
        color: black; 
        border: none; 
        padding: 16px;
        font-size: 16px; 
        font-weight: 800; 
        border-radius: 16px; 
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
        width: 100%; 
        margin-top: 8px;
