.swipe-bg svg { margin-left: 20px; flex-shrink: 0; transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1); }
.list-item-num { color: var(--text-secondary); font-size: 16px; text-align: center; font-variant-numeric: tabular-nums; }
.list-item-title { font-size: 16px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.list-item-artist { font-size: 14px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.list-item-time { color: var(--text-secondary); font-size: 14px; text-align: right; font-variant-numeric: tabular-nums; }

.stat-bar { position: absolute; left: 4px; top: 4px; bottom: 4px; background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(4px); border-right: 1px solid rgba(255,255,255,0.3); border-radius: 6px; z-index: 0; width: 0; opacity: 0; transition: width 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.3s; pointer-events: none; }
.list-container.show-stats .stat-bar { width: calc(var(--stat-w, 0%) - 8px); opacity: 1; }

#ps2-tower-container { display: flex; align-items: center; justify-content: center; height: 350px; padding: 24px; margin: 0 24px 120px 24px; perspective: 1500px; overflow: visible; opacity: 0; transform: translateY(40px); transition: opacity 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1); }
#ps2-tower-container.active-view { opacity: 1; transform: translateY(0); }
.ps2-grid { display: flex; gap: 16px; transform-style: preserve-3d; transform: rotateX(55deg) rotateZ(-45deg); width: 100%; max-width: 320px; justify-content: center; flex-wrap: wrap; }
.ps2-tower { position: relative; width: 24px; height: 24px; transform-style: preserve-3d; transition: transform 0.3s; cursor: pointer; }
.ps2-tower:hover { transform: translateZ(20px); z-index: 10; }
.ps2-face { position: absolute; border: 1px solid rgba(255,255,255,0.2); }
.ps2-top { width: 24px; height: 24px; background: var(--accent-color); transform: translateZ(calc(var(--tower-h) * 1px)); display: flex; align-items: center; justify-content: center; color: #000; font-weight: 900; font-size: 10px; box-shadow: inset 0 0 10px rgba(0,0,0,0.3); transition: background 0.3s, transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1); }
.ps2-front { width: 100%; height: calc(var(--tower-h) * 1px); bottom: 0; left: 0; transform-origin: bottom center; transform: rotateX(-90deg); background: linear-gradient(to bottom, rgba(255,255,255,0.4), rgba(255,255,255,0.05)); transition: height 0.8s cubic-bezier(0.2, 0.8, 0.2, 1); }
.ps2-right { width: calc(var(--tower-h) * 1px); height: 100%; bottom: 0; right: 0; transform-origin: bottom right; transform: rotateX(-90deg) rotateY(90deg); background: linear-gradient(to right, rgba(200,200,200,0.3), rgba(200,200,200,0.05)); transition: width 0.8s cubic-bezier(0.2, 0.8, 0.2, 1); }
.ps2-tooltip { position: absolute; bottom: calc(100% + 12px); left: 50%; transform: translateX(-50%) translateY(10px) rotateZ(45deg) rotateX(-55deg); transform-origin: bottom center; background: rgba(0,0,0,0.9); padding: 8px 12px; border-radius: 4px; font-size: 12px; font-weight: 600; white-space: nowrap; color: #fff; opacity: 0; pointer-events: none; transition: opacity 0.2s, transform 0.2s; border: 1px solid rgba(255,255,255,0.1); z-index: 20; box-shadow: 0 8px 16px rgba(0,0,0,0.5); }
.ps2-tower:hover .ps2-tooltip { opacity: 1; transform: translateX(-50%) translateY(0) rotateZ(45deg) rotateX(-55deg); }
.ps2-tower:hover .ps2-top { background: var(--text-primary); }

#tracks-container { opacity: 0; transform: translateY(20px); transition: opacity 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1); }
#tracks-container.active-view { opacity: 1; transform: translateY(0); }

.corp-footer { margin-top: auto; padding: 64px 24px 48px 24px; text-align: center; border-top: 1px solid rgba(255,255,255,0.05); color: var(--text-secondary); font-size: 13px; line-height: 1.6; }
.corp-footer h3 { font-size: 20px; color: var(--text-primary); margin-bottom: 16px; letter-spacing: 3px; font-weight: 900; }
.corp-footer p { margin-bottom: 8px; }

#toast-msg { position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--accent-color, #1db954); color: #000; padding: 12px 24px; border-radius: 32px; font-weight: 700; font-size: 14px; z-index: 10000; opacity: 0; pointer-events: none; transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1); box-shadow: 0 8px 16px rgba(0,0,0,0.5); white-space: nowrap; }
#toast-msg.show { opacity: 1; transform: translateX(-50%) translateY(0); }
.lrc-line { font-size: 24px; font-weight: 700; color: rgba(255,255,255,0.2); margin-bottom: 12px; transition: all 0.3s; }
.lrc-line.active { color: var(--text-primary); transform: scale(1.1); }
#lyrics-display { padding: 40px 24px; max-height: 400px; overflow-y: hidden; }

@media (max-width: 850px) {
    .mobile-only { display: flex !important; }
    #app-layout { grid-template-columns: 1fr; grid-template-rows: 1fr auto; }
    #right-sidebar { display: none !important; }
    
    #sidebar {
        position: absolute !important;
        left: 0 !important;
        top: 0 !important;
        height: 100% !important;
        width: 260px !important;
        background: rgba(0,0,0,0.95) !important;
        backdrop-filter: blur(10px);
        z-index: 10005 !important;
        transform: translateX(-100%) !important;
        transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1) !important;
        display: flex !important;
        border-right: 1px solid rgba(255,255,255,0.1);
    }
    #sidebar.mobile-active { 
        transform: translateX(0) !important; 
        box-shadow: 4px 0 32px rgba(0,0,0,0.8) !important; 
    }

    #main-view { grid-column: 1; grid-row: 1; height: 100%; overflow-y: auto; overflow-x: hidden; max-width: 100vw; }
    .album-hero { flex-direction: column; align-items: center; text-align: center; }
    .album-meta { justify-content: center; }
    .album-title { font-size: 32px; }
    .edit-trigger { opacity: 1; }
    .grid-container { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 16px; padding: 16px; }
    .card { padding: 12px; gap: 8px; }
    .card-title { font-size: 13px; }
    
    #topbar { padding: 12px 16px; gap: 8px; width: 100%; box-sizing: border-box; }
    #nav-context { min-width: 0; overflow: hidden; text-overflow: ellipsis; font-size: 16px; }
    .search-container { flex: 1; min-width: 0; max-width: none; }
    #search-input { width: 100%; min-width: 0; }
    
    #right-sidebar { position: fixed !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100vh !important; background: #000 !important; z-index: 10002 !important; transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1); display: flex !important; border: none !important; }
    #right-sidebar.mobile-active { transform: translateY(0); }
    
    #ps2-tower-container { height: 250px; padding: 16px; margin: 16px 16px 120px 16px; }
    
    .list-header { grid-template-columns: 30px 1fr 40px; padding: 8px 12px; font-size: 10px; }
