#full-player {
    position: fixed;
    top: 0;
    bottom: 0;
    height: 100dvh;
    padding-bottom: 120px;
    right: 0;
    left: 0;
    width: 100vw;
    max-width: 100%;
    background-color: #000000;
    background-image: linear-gradient(to bottom, var(--accent-dark, #222222) 0%, #000000 85%);
    z-index: 9998;
    display: flex;
    flex-direction: column;
    padding-top: 32px;
    padding-left: 24px;
    padding-right: 24px;
    box-sizing: border-box;
    transition: transform 0.6s cubic-bezier(0.32, 0.72, 0, 1), visibility 0.6s, background-image 0.8s ease;
    transform: translateY(100%);
    visibility: hidden;
    pointer-events: none;
    border-left: 1px solid rgba(255,255,255,0.05);
    overflow-y: auto;
    overflow-x: hidden;
}
#full-player.active { 
    transform: translateY(0); 
    visibility: visible;
    pointer-events: auto;
}

@media (min-width: 851px) {
    #full-player {
        width: 380px;
        left: auto;
    }
}

.fp-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; padding-top: env(safe-area-inset-top, 16px); flex-shrink: 0; }
.fp-header button { background: none; border: none; color: #fff; padding: 8px; cursor: pointer; }
.fp-cover-container { width: 100%; aspect-ratio: 1/1; margin-top: 16px; margin-bottom: 32px; border-radius: 12px; overflow: hidden; box-shadow: 0 16px 80px var(--accent-dark) !important; transition: box-shadow 0.8s cubic-bezier(0.2, 0.8, 0.2, 1); flex-shrink: 0; }
.fp-cover-container img { width: 100%; height: 100%; object-fit: cover; will-change: transform; }

.fp-info {
    position: relative;
    margin-bottom: 24px;
    width: 100%;
    min-height: 56px; 
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    overflow: hidden;
    flex-shrink: 0;
}
.fp-title { font-size: 24px; font-weight: 800; color: #ffffff; margin-bottom: 4px; white-space: nowrap; overflow: visible; }
.fp-artist { font-size: 16px; color: var(--text-secondary, #a0a0a0); white-space: nowrap; text-overflow: ellipsis; overflow: hidden; }

.marquee { display: inline-block; animation: marquee-anim 7s linear infinite alternate; animation-delay: 1.5s; padding-right: 48px; }
@keyframes marquee-anim { 0%, 15% { transform: translateX(0); } 85%, 100% { transform: translateX(var(--scroll-dist)); } }

.fp-progress-container {
    width: 100%;
    height: 4px !important;
    min-height: 4px !important;
    max-height: 4px !important;
    flex: 0 0 4px !important;
    background: rgba(255,255,255,0.2);
    border-radius: 2px;
    margin-bottom: 8px;
    cursor: pointer;
    position: relative;
    display: block;
    overflow: hidden !important;
}
.fp-progress-bar { height: 100%; background: #fff; border-radius: 2px; width: 0%; transition: width 0.1s linear;}
.fp-time { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-secondary, #a0a0a0); margin-bottom: 24px; flex: 0 0 auto; }

.fp-controls { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; flex: 0 0 auto; }
.fp-controls button { background: none; border: none; color: #fff; cursor: pointer; }
.fp-controls .active { color: var(--accent-color) !important; }
.fp-btn-main { width: 64px; height: 64px; background: #fff !important; color: #000 !important; border-radius: 50%; display: flex; align-items: center; justify-content: center; position: relative; flex-shrink: 0; }
.fp-btn-main svg { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); }

.hidden { display: none !important; }

.fp-sliders { background: transparent; padding: 0; display: flex; flex-direction: column; gap: 12px; flex: 0 0 auto; padding-bottom: 48px; }
.fp-slider-row { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.03); padding: 8px 16px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); }
.fp-slider-row span { font-size: 11px; font-weight: 700; color: var(--text-secondary); width: 32px; text-align: right; }
.fp-slider-row input[type=range] { flex-grow: 1; height: 4px; min-height: 4px; -webkit-appearance: none; background: rgba(255,255,255,0.1); border-radius: 2px; outline: none; }
.fp-slider-row input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 12px; height: 12px; border-radius: 50%; background: var(--text-primary); cursor: pointer; transition: transform 0.2s, background 0.2s; }
.fp-slider-row input[type=range]:hover::-webkit-slider-thumb { transform: scale(1.4); background: var(--accent-color); }
