                        {/if}
                    </div>
                </div>
            </details>

            <div style="display: flex; gap: 12px; margin-top: 8px;">
                <button class="btn-save" on:click={saveArtist}>Save</button>
                <button class="btn-cancel" on:click={toggleEdit}>Cancel</button>
