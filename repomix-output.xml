            <div id="now-playing">
                <span id="np-title">{track ? track.title : '---'}</span>
                <span id="np-artist">{album ? album.artistName : '---'}</span>
            </div>
        </div>

        <div id="controls">
            <button class="btn-icon hide-on-mobile" aria-label="Shuffle" class:active={$isShuffle} on:click={() => isShuffle.set(!$isShuffle)}>
