    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
    const key = e.key ? e.key.toLowerCase() : '';
    switch(key) {
      case ' ': e.preventDefault(); togglePlay(); break;
      case 'l':
