    @media (max-width: 768px) {
        .app-row.max-glass-layout { padding: 12px 12px 0 12px; gap: 12px; }

        :global(.app-row > aside:first-child) {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            height: 100dvh !important;
            z-index: 100005 !important;
