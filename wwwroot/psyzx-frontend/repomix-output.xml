                        {line.text}
                    </div>
                {/each}
            </div>
        </div>
    {/if}
{/if}

{#if showDiagnostics}
        <div class="lyrics-modal-popup" style="z-index: 9999999999;" use:portal={true} in:fly={{y: '100%', duration: 400, easing: expoOut}} out:fly={{y: '100%', duration: 200, easing: expoIn}}>
